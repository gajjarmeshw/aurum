# Twelve Data (primary feed)
TWELVE_DATA_API_KEY=your_twelve_data_key

# Finnhub (fallback feed)
FINNHUB_API_KEY=your_finnhub_key
FINNHUBFRED_API_KEY=your_fred_key

# SSL (Set to true if you get [SSL: CERTIFICATE_VERIFY_FAILED] on macOS)
SSL_NO_VERIFY=false

# NewsAPI (sentiment)
NEWSAPI_KEY=your_newsapi_key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=chat_id1,chat_id2  # Can be a single ID or comma-separated list

# Server
FLASK_SECRET_KEY=generate_a_random_secret
HOST=0.0.0.0
PORT=5000
DEBUG=false
